# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Backend Integration
BACKEND_URL=http://localhost:3001

# Simulation Mode (set to False for real image processing)
SIMULATION_MODE=true

# Computer Vision Configuration
OPENCV_THREADS=4
MAX_IMAGE_SIZE=1920

# Calibration
REFERENCE_POL_VALUE=95.0

# Logging
LOG_LEVEL=INFO
